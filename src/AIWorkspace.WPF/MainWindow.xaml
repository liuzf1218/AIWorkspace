<Window x:Class="AIWorkspace.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AI Workspace"
        Width="1280"
        Height="800"
        MinWidth="800"
        MinHeight="600"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu x:Name="TopMenu" DockPanel.Dock="Top">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Padding" Value="14,6" />
                    <Setter Property="FontSize" Value="13" />
                </Style>
            </Menu.Resources>
            <MenuItem Header="登录" Click="MenuLogin_Click" />
            <MenuItem Header="设置" Click="MenuSettings_Click" />
            <MenuItem Header="关于" Click="MenuAbout_Click" />
        </Menu>
        <wv2:WebView2 x:Name="WebView" />
    </DockPanel>
</Window>
